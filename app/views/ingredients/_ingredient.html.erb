<div id="<%= dom_id ingredient %>" class="bg-[#1a1a1a] border border-[#333] rounded-lg p-4 shadow-md w-full sm:w-auto space-y-3">
  <div>
    <strong class="block text-sm font-semibold text-gray-300">Nom :</strong>
    <p class="text-lg font-medium text-white"><%= ingredient.name %></p>
  </div>
  <div>
    <strong class="block text-sm font-semibold text-gray-300">Allergène :</strong>
    <span class="<%= ingredient.is_allergen? ? 'text-red-500 font-semibold' : 'text-green-500' %>">
      <%= ingredient.is_allergen? ? "Oui ⚠️" : "Non" %>
    </span>
  </div>
</div>
