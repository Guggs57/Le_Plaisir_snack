<% content_for :title, "Mon Panier" %>

<div class="container panier-wrapper mt-5 pt-5">
  <h1 class="page-title">Mon Panier</h1>

  <% if @cart_dishes.empty? %>
    <p class="empty-message">Votre panier est vide.</p>
  <% else %>
    <% total_panier = 0 %>
    <% @cart_dishes.each do |cart_dish| %>
      <% total_panier += cart_dish.total_price %>

      <div class="cart-item-card">
        <div class="cart-item-body">
          <div class="cart-item-info">
            <h5 class="cart-item-title">
              <% if cart_dish.menu_option %>
                MENU - <%= cart_dish.dish.title %>
              <% else %>
                <%= cart_dish.dish.title %>
              <% end %>
            </h5>
            <p>Quantité : <%= cart_dish.quantity %></p>
            <p>Prix unitaire : <%= number_to_currency(cart_dish.unit_price) %></p>
            <p class="subtotal">Sous-total : <%= number_to_currency(cart_dish.total_price) %></p>

            <% if cart_dish.ingredients.blank? %>
              <p class="default-ingredients">Ingrédients par défaut.</p>
            <% else %>
              <p class="removed-ingredients-label">Ingrédients retirés :</p>
              <ul class="removed-ingredients-list">
                <% cart_dish.ingredients.each do |ingr| %>
                  <li><%= ingr.capitalize %></li>
                <% end %>
              </ul>
            <% end %>
          </div>

          <div class="cart-item-actions">
            <%= link_to "Modifier", edit_cart_dish_path(cart_dish), class: "btn btn-outline-primary btn-sm mb-2" %>
            <%= button_to "Supprimer", cart_dish_path(cart_dish), method: :delete, data: { confirm: "Êtes-vous sûr ?" }, class: "btn btn-danger btn-sm" %>
          </div>
        </div>
      </div>
    <% end %>

    <hr>
    <p class="total-price">Total : <%= number_to_currency(total_panier) %></p>

    <%= link_to "Passer la commande", new_order_path, class: "btn btn-success btn-lg mt-3" %>
  <% end %>
</div>
