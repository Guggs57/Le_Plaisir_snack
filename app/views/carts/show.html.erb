<h1>Mon Panier</h1>

<% if @cart_dishes.any? %>
  <table class="cart-table">
    <thead>
      <tr>
        <th>Article</th>
        <th>Quantité</th>
        <th>Prix</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @cart_dishes.each do |cart_dish| %>
        <tr>
          <td><%= cart_dish.dish.title %></td>
          <td><%= cart_dish.quantity %></td>
          <td><%= number_to_currency(cart_dish.total_price, unit: "€") %></td>
          <td>
            <%= button_to "Retirer", cart_dish_path(cart_dish), method: :delete, class: "btn btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="cart-footer">
    <p>Total : <%= number_to_currency(@cart.total_price, unit: "€") %></p>
    <%= button_to "Passer commande", orders_path, method: :post, class: "btn btn-primary" %>
  </div>
<% else %>
  <p>Votre panier est vide.</p>
  <%= link_to "Retour à la carte", dishes_path, class: "btn btn-secondary" %>
<% end %>
