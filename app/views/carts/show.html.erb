<h1>Mon Panier</h1>

<% total_price = 0 %>

<% @cart.cart_dishes.each do |cart_dish| %>
  <div class="flex items-center justify-between mb-4">
    <div>
      <p class="font-bold"><%= cart_dish.dish.title %></p>
      <p><%= number_to_currency(cart_dish.dish.price) %></p>
    </div>
    
    <%= form_with url: update_quantity_cart_dish_path(cart_dish), method: :patch, local: true do |f| %>
      <%= f.number_field :quantity, value: cart_dish.quantity, min: 1, class: "w-16 text-center border rounded" %>
      <%= f.submit "✔️", class: "ml-2 px-2 py-1 bg-green-500 text-white rounded" %>
    <% end %>

    <%= button_to '🗑️', cart_dish_path(cart_dish), method: :delete, data: { turbo_confirm: "Supprimer ?" }, class: "ml-4 px-2 py-1 bg-red-500 text-white rounded" %>
  </div>

  <% total_price += cart_dish.dish.price * cart_dish.quantity %>
<% end %>

<p><strong>Prix total du panier: <%= number_to_currency(total_price) %></strong></p>

<%= link_to '← Retour aux plats', dishes_path, class: 'text-blue-600 hover:underline' %>
