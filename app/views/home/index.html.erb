<div class="home-wrapper">

  <section class="home-banner">
    <div class="home-logo-container">
      <%= image_tag 'leplaisir.jpg', alt: 'Le Plaisir', class: 'home-logo shadowed-logo' %>
    </div>

    <h1 class="home-title neon-text">Restauration rapide halal</h1>
    <p class="home-subtitle">Sur place ou à emporter à <strong>Forbach</strong></p>

    <div class="home-hours">
      <p>
        <i class="fa fa-clock-o"></i>
        <strong>Du lundi au samedi :</strong> 11h00 - 23h00<br>
        <strong>Dimanche :</strong> 11h30 - 23h00
      </p>
    </div>

    <div class="home-cta">
      <%= link_to 'Voir le menu', dishes_path, class: 'btn btn-lg custom-btn-red' %>
    </div>
  </section>

  <section id="student-menu-promo" class="student-menu-promo">
    <h2><i class="fa fa-graduation-cap"></i> Menu étudiant <span class="price-tag">7,50€</span></h2>
    <p>Sur présentation d'une carte étudiante.</p>
  </section>

</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const studentMenu = document.getElementById('student-menu-promo');

    function checkVisibility() {
      const rect = studentMenu.getBoundingClientRect();
      const isVisible = rect.top >= 0 && rect.bottom <= window.innerHeight;

      if (isVisible) {
        studentMenu.classList.add('visible');
      } else {
        studentMenu.classList.remove('visible');
      }
    }

    window.addEventListener('scroll', checkVisibility);
    checkVisibility(); // check immediately on load
  });
</script>
