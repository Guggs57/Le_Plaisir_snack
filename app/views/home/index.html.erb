<!-- app/views/home/index.html.erb -->
<div class="home-banner" style="background-color: #1a1a1a; color: white; text-align: center; padding: 2rem;">
  <img src="<%= asset_path('logo.png') %>" alt="Logo Le Plaisir" style="width: 200px;">
  <h1 style="font-size: 3rem; margin-top: 1rem;">Le Plaisir - Restauration rapide</h1>
  <p style="font-size: 1.2rem;">180 rue Nationale, Forbach - 100% Halal</p>
  <p style="margin-top: 0.5rem;">Ouvert du lundi au samedi de 11h à 23h • Dimanche de 11h30 à 23h</p>

  <div style="margin-top: 2rem;">
    <a href="<%= dishes_path %>" class="btn" style="background-color: red; color: white; padding: 1rem 2rem; margin: 1rem; text-decoration: none; font-weight: bold;">Voir la carte</a>
    <% if user_signed_in? %>
      <a href="<%= cart_path %>" class="btn" style="background-color: white; color: red; padding: 1rem 2rem; margin: 1rem; text-decoration: none; font-weight: bold;">Commander</a>
    <% else %>
      <a href="<%= new_user_session_path %>" class="btn" style="background-color: white; color: red; padding: 1rem 2rem; margin: 1rem; text-decoration: none; font-weight: bold;">Se connecter</a>
    <% end %>
  </div>
</div>

<div style="background-color: #f5f5f5; color: #333; padding: 2rem; text-align: center;">
  <h2 style="color: red;">Menus Spéciaux</h2>
  <ul style="list-style: none; padding: 0; font-size: 1.1rem;">
    <li><strong>Menu étudiant</strong> : Sandwich + Frites + Boisson 33cl – 7,50€</li>
    <li><strong>Menu kids</strong> : Nuggets/Kebab/Pâtes + Frites + Boisson – 7€</li>
    <li><strong>Menu Kébab</strong> : Kébab + Frites + Boisson – 8,50€</li>
  </ul>
</div>
