<div class="home-wrapper">
  <div class="home-logo-container">
    <%= image_tag 'leplaisir.jpg', alt: 'Le Plaisir', class: 'home-logo shadowed-logo' %>
  </div>

  <div class="home-content">
    <section class="student-menu-promo">
      🎓 <strong>Menu étudiant</strong><br>
      Tacos ou sandwich + frites + boisson<br>
      <span class="price-tag">6,50€</span>
    </section>

    <section class="home-banner">
      <h1 class="home-title neon-text">
        Restauration rapide halal
      </h1>

      <p class="home-subtitle">
        Sur place ou à emporter à <strong>Forbach</strong>
      </p>

      <div class="home-hours">
        <p>
          <i class="fa fa-clock-o" aria-hidden="true"></i>
          <strong>Du lundi au samedi :</strong> 11h00 - 23h00<br>
          <strong>Dimanche :</strong> 11h30 - 23h00
        </p>
      </div>

      <div class="home-cta">
        <%= link_to 'Voir le menu', dishes_path, class: 'btn btn-lg custom-btn-red' %>
      </div>
    </section>
  </div>
</div>
