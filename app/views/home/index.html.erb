<div class="home-wrapper">
  <section class="home-banner">
    <div class="home-logo-container">
      <%= image_tag 'leplaisir.jpg', alt: 'Le Plaisir', class: 'home-logo' %>
    </div>

    <h1 class="home-title">Restauration rapide halal</h1>
    <p class="home-subtitle">Sur place ou à emporter à Forbach</p>

    <div class="home-hours">
      <p>
        <i class="fa fa-calendar"></i>
        <strong>Du lundi au samedi :</strong> 11h00 - 23h00<br>
        <strong>Dimanche :</strong> 11h30 - 23h00
      </p>
    </div>

    <div class="home-cta">
      <%= link_to 'Voir le menu', dishes_path, class: 'btn btn-primary' %>
    </div>
  </section>

  <section class="student-offer">
    <h2>Menu étudiant <span>7,50€</span></h2>
    <small>Sur présentation d'une carte étudiante</small>
  </section>
</div>
