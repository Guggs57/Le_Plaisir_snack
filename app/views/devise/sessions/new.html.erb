<h2 class="mb-4 text-center">Connexion</h2>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: {class: "needs-validation"}) do |f| %>
      <div class="form-group mb-3">
        <%= f.input :email, 
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email", class: "form-control", placeholder: "Adresse email" },
                    label: false %>
      </div>

      <div class="form-group mb-3">
        <%= f.input :password, 
                    required: true,
                    input_html: { autocomplete: "current-password", class: "form-control", placeholder: "Mot de passe" },
                    label: false %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-check mb-3">
          <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi", input_html: {class: "form-check-input"}, wrapper_html: {class: "form-check"} %>
        </div>
      <% end %>

      <div class="d-grid">
        <%= f.button :submit, "Se connecter", class: "btn btn-danger" %>
      </div>
    <% end %>

    <div class="mt-3 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
