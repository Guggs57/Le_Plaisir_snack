<h2 class="mb-4 text-center">Inscription</h2>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: {class: "needs-validation"}) do |f| %>
      <div class="form-group mb-3">
        <%= f.input :email, 
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email", class: "form-control", placeholder: "Adresse email" },
                    label: false %>
      </div>

      <div class="form-group mb-3">
        <%= f.input :password, 
                    required: true,
                    input_html: { autocomplete: "new-password", class: "form-control", placeholder: "Mot de passe" },
                    label: false %>
      </div>

      <div class="form-group mb-3">
        <%= f.input :password_confirmation, 
                    required: true,
                    input_html: { autocomplete: "new-password", class: "form-control", placeholder: "Confirmer le mot de passe" },
                    label: false %>
      </div>

      <div class="d-grid">
        <%= f.button :submit, "S'inscrire", class: "btn btn-danger" %>
      </div>
    <% end %>

    <div class="mt-3 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
