<h2>Modifier mon profil</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <% if resource.errors.any? %>
    <div class="errors">
      <h3>⚠️ Erreurs :</h3>
      <ul>
        <% resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :email, "Adresse e‑mail" %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
  </div>

  <div class="field">
    <%= f.label :password, "Nouveau mot de passe" %> <small>(laisser vide si inchangé)</small><br />
    <%= f.password_field :password, autocomplete: "new-password" %>
  </div>

  <div class="field">
    <%= f.label :password_confirmation, "Confirmation du mot de passe" %><br />
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
  </div>

  <div class="field">
    <%= f.label :current_password, "Mot de passe actuel" %> <small>(requis pour modifier l’email ou le mot de passe)</small><br />
    <%= f.password_field :current_password, autocomplete: "current-password" %>
  </div>

  <div class="actions">
    <%= f.submit "Mettre à jour", class: "btn", style: "margin-top: 1rem;" %>
  </div>
<% end %>

<hr>

<h3>⚠️ Supprimer mon compte</h3>
<%= button_to "Supprimer", registration_path(resource_name), method: :delete, data: { confirm: "Es-tu sûr de vouloir supprimer ton compte ?" }, class: "btn", style: "background-color: red; color: white;" %>
