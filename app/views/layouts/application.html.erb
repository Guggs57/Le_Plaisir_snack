<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="mobile-web-app-capable" content="yes" />
  <title><%= content_for(:title) || "Le Plaisir Snack" %></title>

  <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", crossorigin: "anonymous" %>
  <%= stylesheet_link_tag "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css", crossorigin: "anonymous" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= javascript_include_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js", crossorigin: "anonymous" %>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>
</head>

<body>
  <% flash.each do |key, value| %>
    <div class="alert alert-<%= key == "notice" ? "success" : "danger" %> alert-dismissible fade show" role="alert">
      <%= value %>
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <%= render 'layouts/navbar' %>

  <main class="container mt-5 pt-4 position-relative" style="z-index: 10;">
    <%= yield %>
  </main>

  <div class="wave-container" aria-hidden="true" focusable="false" tabindex="-1">
    <svg viewBox="0 0 1440 320" preserveAspectRatio="none" style="width:100%; height:100%; display:block;">
      <path fill="#d62828" fill-opacity="1" d="M0,64L60,96C120,128,240,192,360,197.3C480,203,600,149,720,149.3C840,149,960,203,1080,213.3C1200,224,1320,192,1380,176L1440,160L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"></path>
    </svg>
  </div>

  <%= render 'layouts/footer' %>

  <script>
    window.addEventListener('scroll', () => {
      const hauteurPage = window.innerHeight;
      const scrollY = window.scrollY;
      const seuil = document.body.scrollHeight - hauteurPage * 0.5;

      const content = document.querySelector('.home-wrapper');

      if (content) {
        if (scrollY + hauteurPage > seuil) {
          content.classList.add('on-wave');
        } else {
          content.classList.remove('on-wave');
        }
      }
    });
  </script>
</body>

</html>
