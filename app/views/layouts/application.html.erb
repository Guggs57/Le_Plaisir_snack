<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <title>Le Plaisir - Snack Halal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag 'application', media: 'all' %>
  <!-- Pas de javascript_include_tag ici, pour ne pas charger de JS -->
</head>

<body>
  <header>
    <nav class="navbar">
      <div class="navbar-container">
        <div class="navbar-logo">
          <!-- Ici tu peux mettre un logo si tu en as, sinon juste le texte -->
          <h1>Le Plaisir, <span class="navbar-slogan">votre restauration rapide préférée</span></h1>
        </div>
        <ul class="navbar-menu">
          <li><%= link_to 'Accueil', root_path %></li>
          <li><%= link_to 'Menu', dishes_path %></li>
          <% if user_signed_in? %>
            <li><%= link_to 'Mon panier', cart_path(current_user.cart) %></li>
            <li><%= link_to 'Déconnexion', destroy_user_session_path, method: :delete %></li>
          <% else %>
            <li><%= link_to 'Connexion', new_user_session_path %></li>
            <li><%= link_to 'Inscription', new_user_registration_path %></li>
          <% end %>
        </ul>
      </div>
    </nav>
  </header>

  <main>
    <% if notice %>
      <p class="notice"><%= notice %></p>
    <% end %>
    <% if alert %>
      <p class="alert"><%= alert %></p>
    <% end %>

    <%= yield %>
  </main>

  <footer>
    <p>© 2025 Le Plaisir - Tous droits réservés</p>
  </footer>
</body>
</html>
