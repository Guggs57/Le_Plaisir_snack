<% content_for :title, "Détail de l'article dans le panier" %>

<div class="container my-5">
  <% if notice.present? %>
    <div class="alert alert-success" id="notice">
      <%= notice %>
      <button type="button" class="alert-close" aria-label="Fermer">&times;</button>
    </div>
  <% end %>

  <h1 class="page-title mb-4">
    <% if @cart_dish.menu_option %>
      MENU - <%= @cart_dish.dish.title %>
    <% else %>
      <%= @cart_dish.dish.title %>
    <% end %>
  </h1>

  <p><strong>Description :</strong> <%= @cart_dish.dish.description %></p>

  <p><strong>Prix unitaire :</strong>
    <%= number_to_currency(@cart_dish.dish.price, unit: "€") %>
    <% if @cart_dish.menu_option %>
      + <%= number_to_currency(2.5, unit: "€") %> (supplément menu)
    <% end %>
  </p>

  <p><strong>Quantité :</strong> <%= @cart_dish.quantity %></p>

  <% if @cart_dish.dish.image_url.present? %>
    <div class="image-wrapper my-4">
      <%= image_tag @cart_dish.dish.image_url, alt: @cart_dish.dish.title, class: "image-rounded shadow" %>
    </div>
  <% end %>

  <p><strong>Sous-total :</strong>
    <% unit_price = @cart_dish.dish.price + (@cart_dish.menu_option ? 2.5 : 0) %>
    <%= number_to_currency(unit_price * @cart_dish.quantity, unit: "€") %>
  </p>

  <% if @cart_dish.ingredients.present? && @cart_dish.ingredients.any? %>
    <p class="ingredients-label">Ingrédients retirés :</p>
    <ul class="ingredients-list">
      <% @cart_dish.ingredients.each do |ingr| %>
        <li><%= ingr.capitalize %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="ingredients-default">Ingrédients par défaut.</p>
  <% end %>

  <div class="actions-group mt-4">
    <%= link_to "Modifier cet article", edit_cart_dish_path(@cart_dish), class: "btn btn-outline-primary action-btn" %>
    <%= link_to "Retour à la liste", cart_dishes_path, class: "btn btn-outline-secondary action-btn" %>
    <%= button_to "Supprimer cet article", @cart_dish, method: :delete, data: { turbo_confirm: "Êtes-vous sûr ?" }, class: "btn btn-danger action-btn" %>
  </div>
</div>
