<% content_for :title, "Modifier le plat dans le panier" %>

<div class="edit-wrapper md:w-2/3 w-full mx-auto p-6 bg-dark rounded-lg shadow-lg">
  <h1 class="edit-title font-bold text-4xl mb-6 text-white">Modifier votre plat</h1>

  <%= form_with(model: @cart_dish, local: true, class: "edit-form") do |form| %>
    <div class="form-group mb-4">
      <%= form.label :quantity, "Quantité", class: "form-label" %>
      <%= form.number_field :quantity, min: 1, class: "form-input w-20" %>
    </div>

    <div class="form-group mb-4">
      <h2 class="section-title font-semibold mb-2 text-white">Ingrédients à retirer</h2>
      <% ingrédients = @cart_dish.dish.ingredients %>
      <% selected_ingredients = @cart_dish.ingredients || [] %>
      <% ingrédients.each do |ingr| %>
        <div class="checkbox-item">
          <%= check_box_tag "cart_dish[ingredients][]", ingr, selected_ingredients.include?(ingr), id: "ingredient_#{ingr.parameterize}" %>
          <%= label_tag "ingredient_#{ingr.parameterize}", ingr.capitalize, class: "checkbox-label" %>
        </div>
      <% end %>
    </div>

    <div class="form-group mb-4">
      <h2 class="section-title font-semibold mb-2 text-white">Sauces (optionnel)</h2>
      <% sauces_disponibles = ["ketchup", "mayonnaise", "harissa", "samouraï"] %>
      <% selected_sauces = @cart_dish.sauces || [] %>
      <% sauces_disponibles.each do |sauce| %>
        <div class="checkbox-item">
          <%= check_box_tag "cart_dish[sauces][]", sauce, selected_sauces.include?(sauce), id: "sauce_#{sauce.parameterize}" %>
          <%= label_tag "sauce_#{sauce.parameterize}", sauce.capitalize, class: "checkbox-label" %>
        </div>
      <% end %>
    </div>

    <div class="form-actions mt-6">
      <%= form.submit "Enregistrer les modifications", class: "btn btn-danger" %>
      <%= link_to "Annuler", cart_path(@cart_dish.cart), class: "btn-cancel ml-4" %>
    </div>
  <% end %>
</div>
