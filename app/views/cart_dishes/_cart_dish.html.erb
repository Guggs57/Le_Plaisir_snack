<div class="cart-dish-card">
  <div class="cart-dish-body">
    <div class="cart-dish-info">
      <h5 class="cart-dish-title">
        <% if cart_dish.menu_option %>
          MENU - <%= cart_dish.dish.title %>
        <% else %>
          <%= cart_dish.dish.title %>
        <% end %>
      </h5>

      <p class="cart-dish-quantity">Quantité : <%= cart_dish.quantity %></p>

      <p class="cart-dish-unit-price">
        Prix unitaire : <%= number_to_currency(cart_dish.unit_price) %>
      </p>

      <p class="cart-dish-total-price">
        Sous-total : <%= number_to_currency(cart_dish.total_price) %>
      </p>

      <% if cart_dish.ingredients.present? && cart_dish.ingredients.any? %>
        <p class="cart-dish-subtitle">Ingrédients retirés :</p>
        <ul class="cart-dish-ingredients-list">
          <% cart_dish.ingredients.each do |ingr| %>
            <li><%= ingr.capitalize %></li>
          <% end %>
        </ul>
      <% else %>
        <p class="cart-dish-all-ingredients">Avec tout</p>
      <% end %>

      <p class="cart-dish-subtitle">Avec sauce :</p>
      <% if cart_dish.sauces.present? && cart_dish.sauces.any? %>
        <ul class="cart-dish-sauces-list">
          <% cart_dish.sauces.each do |sauce| %>
            <li><%= sauce.capitalize %></li>
          <% end %>
        </ul>
      <% else %>
        <ul class="cart-dish-sauces-list">
          <li>Sauce blanche</li>
        </ul>
      <% end %>
    </div>

    <div class="cart-dish-actions">
      <%= link_to "Modifier", edit_cart_dish_path(cart_dish), class: "btn-edit" %>
      <%= button_to "Supprimer", cart_dish_path(cart_dish), method: :delete, data: { confirm: "Êtes-vous sûr ?" }, class: "btn-delete" %>
    </div>
  </div>
</div>
