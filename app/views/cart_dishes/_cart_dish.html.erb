<div class="card mb-3 shadow-sm">
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <h5 class="card-title mb-1">
        <% if cart_dish.menu_option %>
          MENU - <%= cart_dish.dish.title %>
        <% else %>
          <%= cart_dish.dish.title %>
        <% end %>
      </h5>

      <p class="card-text mb-0">Quantité : <%= cart_dish.quantity %></p>

      <p class="card-text">Prix unitaire : 
        <%= number_to_currency(cart_dish.unit_price) %>
      </p>

      <p class="card-text fw-semibold">Sous-total : 
        <%= number_to_currency(cart_dish.total_price) %>
      </p>

      <%# --- Ingrédients retirés --- %>
      <% if cart_dish.ingredients.present? && cart_dish.ingredients.any? %>
        <p class="mt-2 mb-0 fw-semibold">Ingrédients retirés :</p>
        <ul>
          <% cart_dish.ingredients.each do |ingr| %>
            <li><%= ingr.capitalize %></li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-2 mb-0 fst-italic">Avec tout</p>
      <% end %>

      <%# --- Sauces choisies ou par défaut --- %>
      <p class="mt-2 mb-0 fw-semibold">Avec sauce :</p>
      <% if cart_dish.sauces.present? && cart_dish.sauces.any? %>
        <ul>
          <% cart_dish.sauces.each do |sauce| %>
            <li><%= sauce.capitalize %></li>
          <% end %>
        </ul>
      <% else %>
        <ul>
          <li>Sauce blanche</li>
        </ul>
      <% end %>
    </div>

    <div class="d-flex flex-column align-items-end">
      <%= link_to "Modifier", edit_cart_dish_path(cart_dish), class: "btn btn-outline-primary btn-sm mb-2" %>
      <%= button_to "Supprimer", cart_dish_path(cart_dish), method: :delete, data: { confirm: "Êtes-vous sûr ?" }, class: "btn btn-danger btn-sm" %>
    </div>
  </div>
</div>
