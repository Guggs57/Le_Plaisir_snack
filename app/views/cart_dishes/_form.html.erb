<%= form_with(model: cart_dish, local: true, class: "cart-dish-form") do |form| %>
  <% if cart_dish.errors.any? %>
    <div class="error-messages">
      <h2><%= pluralize(cart_dish.errors.count, "error") %> prohibited this cart dish from being saved:</h2>
      <ul>
        <% cart_dish.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field-group">
    <%= form.label :dish_id, "Plat" %>
    <%= form.collection_select :dish_id, Dish.all, :id, :title, prompt: "Choisissez un plat" %>
  </div>

  <div class="field-group">
    <%= form.label :quantity, "Quantité" %>
    <%= form.number_field :quantity, min: 1 %>
  </div>

  <% if cart_dish.dish.present? %>
    <div class="ingredients-section">
      <p>Ingrédients (modifiable):</p>
      <% cart_dish.dish.ingredients.each do |ingredient| %>
        <div>
          <%= check_box_tag "cart_dish[ingredients][]", ingredient.id, cart_dish.ingredients.include?(ingredient.id.to_s), id: "ingredient_#{ingredient.id}" %>
          <%= label_tag "ingredient_#{ingredient.id}", ingredient.name %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="sauces-section">
    <p>Sauces :</p>
    <% ["Ketchup", "Mayonnaise", "Samurai"].each do |sauce| %>
      <div>
        <%= check_box_tag "cart_dish[sauces][]", sauce, cart_dish.sauces.include?(sauce), id: "sauce_#{sauce.parameterize}" %>
        <%= label_tag "sauce_#{sauce.parameterize}", sauce %>
      </div>
    <% end %>
  </div>

  <div class="form-submit">
    <%= form.submit "Valider" %>
  </div>
<% end %>
