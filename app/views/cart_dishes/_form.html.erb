<%= form_with(model: cart_dish, class: "contents") do |form| %>
  <% if cart_dish.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(cart_dish.errors.count, "error") %> prohibited this cart_dish from being saved:</h2>

      <ul class="list-disc ml-6">
        <% cart_dish.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :cart_id %>
    <%= form.text_field :cart_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": cart_dish.errors[:cart_id].none?, "border-red-400 focus:outline-red-600": cart_dish.errors[:cart_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :dish_id %>
    <%= form.text_field :dish_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": cart_dish.errors[:dish_id].none?, "border-red-400 focus:outline-red-600": cart_dish.errors[:dish_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :quantity %>
    <%= form.number_field :quantity, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": cart_dish.errors[:quantity].none?, "border-red-400 focus:outline-red-600": cart_dish.errors[:quantity].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
