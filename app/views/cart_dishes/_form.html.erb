<%= form_with(model: cart_dish, local: true, class: "contents") do |form| %>
  <% if cart_dish.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(cart_dish.errors.count, "error") %> prohibited this cart dish from being saved:</h2>
      <ul class="list-disc ml-6">
        <% cart_dish.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :dish_id, "Plat" %>
    <%= form.collection_select :dish_id, Dish.all, :id, :title, prompt: "Choisissez un plat", class: "block w-full rounded-md border px-3 py-2" %>
  </div>

  <div class="my-5">
    <%= form.label :quantity, "Quantité" %>
    <%= form.number_field :quantity, min: 1, class: "block w-full rounded-md border px-3 py-2" %>
  </div>

  <%# Afficher les ingrédients disponibles pour le plat sélectionné (en mode edit) %>
  <% if cart_dish.dish.present? %>
    <div class="my-5">
      <p class="font-semibold mb-2">Ingrédients (modifiable):</p>
      <% cart_dish.dish.ingredients.each do |ingredient| %>
        <div>
          <%= check_box_tag "cart_dish[ingredients][]", ingredient.id, cart_dish.ingredients.include?(ingredient.id.to_s), id: "ingredient_#{ingredient.id}" %>
          <%= label_tag "ingredient_#{ingredient.id}", ingredient.name %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Pour les sauces, tu peux faire pareil si tu as une table sauces ou options similaires %>
  <%# Exemple statique : %>
  <div class="my-5">
    <p class="font-semibold mb-2">Sauces :</p>
    <% ["Ketchup", "Mayonnaise", "Samurai"].each do |sauce| %>
      <div>
        <%= check_box_tag "cart_dish[sauces][]", sauce, cart_dish.sauces.include?(sauce), id: "sauce_#{sauce.parameterize}" %>
        <%= label_tag "sauce_#{sauce.parameterize}", sauce %>
      </div>
    <% end %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
  </div>
<% end %>
