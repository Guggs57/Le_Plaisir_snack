<%= form_with(model: order_dish, class: "order-dish-form") do |form| %>
  <% if order_dish.errors.any? %>
    <div id="error_explanation" class="form-errors">
      <h2><%= pluralize(order_dish.errors.count, "error") %> prohibited this order dish from being saved:</h2>

      <ul>
        <% order_dish.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :order_id %>
    <%= form.text_field :order_id, class: ["form-input", {"input-error": order_dish.errors[:order_id].any?}] %>
  </div>

  <div class="form-group">
    <%= form.label :dish_id %>
    <%= form.text_field :dish_id, class: ["form-input", {"input-error": order_dish.errors[:dish_id].any?}] %>
  </div>

  <div class="form-group">
    <%= form.label :quantity %>
    <%= form.number_field :quantity, class: ["form-input", {"input-error": order_dish.errors[:quantity].any?}] %>
  </div>

  <div class="form-submit">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
