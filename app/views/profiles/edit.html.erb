<h2>Mon Profil</h2>

<%= form_for(@user, url: profile_path, method: :put) do |f| %>
  <div class="form-group">
    <%= f.label :name, "Nom" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="form-group mt-3">
    <%= f.label :email, "Email" %>
    <%= f.email_field :email, class: "form-control" %>
  </div>

  <div class="form-group mt-3">
    <%= f.submit "Mettre à jour", class: "btn btn-primary" %>
  </div>
<% end %>

<h3 class="mt-4">Changer mon mot de passe</h3>
<%= link_to "Modifier le mot de passe", new_user_password_path, class: "btn btn-warning" %>

<h3 class="mt-4">Supprimer mon compte</h3>
<%= button_to "Supprimer mon compte", destroy_profile_path, method: :delete, data: { confirm: "Êtes-vous sûr de vouloir supprimer votre compte ? Cette action est irréversible." }, class: "btn btn-danger" %>
