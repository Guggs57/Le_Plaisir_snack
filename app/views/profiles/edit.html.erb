<div class="profile-edit">
  <h2 class="profile-title">Mon Profil</h2>

  <%= form_for(@user, url: profile_path, method: :put, html: { class: "profile-form" }) do |f| %>
    <div class="form-group">
      <%= f.label :name, "Nom", class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= f.label :email, "Email", class: "form-label" %>
      <%= f.email_field :email, class: "form-control" %>
    </div>

    <div class="form-actions">
      <%= f.submit "Mettre à jour", class: "btn btn-primary" %>
    </div>
  <% end %>

  <div class="profile-section">
    <h3>Changer mon mot de passe</h3>
    <%= link_to "Modifier le mot de passe", new_user_password_path, class: "btn btn-secondary" %>
  </div>

  <div class="profile-section">
    <h3>Supprimer mon compte</h3>
    <%= button_to "Supprimer mon compte", destroy_profile_path, method: :delete, data: { confirm: "Êtes-vous sûr de vouloir supprimer votre compte ? Cette action est irréversible." }, class: "btn btn-danger" %>
  </div>
</div>
