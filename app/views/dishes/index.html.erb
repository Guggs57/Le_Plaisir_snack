<div class="w-full max-w-6xl mx-auto px-4">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-100 mb-5 text-green-700 font-medium rounded-md shadow-sm" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl text-gray-800">La carte</h1>
    <% if current_user&.admin? %>
      <%= link_to "Nouveau plat", new_dish_path, class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold shadow-md" %>
    <% end %>
  </div>

  <% if @dishes.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      <% @dishes.each do |dish| %>
        <div class="bg-white rounded-lg shadow-md p-4 flex flex-col justify-between">
          <div>
            <h3 class="text-xl font-semibold text-gray-800 mb-1"><%= dish.title %></h3>
            <p class="text-gray-600 mb-2"><%= dish.description %></p>
            <p class="text-lg font-bold text-gray-900"><%= number_to_currency(dish.price) %></p>
          </div>

          <div class="mt-4">
            <% if @cart.present? %>
              <%= button_to 'Ajouter au panier', add_to_cart_cart_path(@cart.id, dish_id: dish.id), method: :post, class: "w-full px-4 py-2 bg-green-600 hover:bg-green-500 text-white rounded-md font-medium" %>
            <% else %>
              <p class="text-red-500 text-sm">Connectez-vous pour ajouter au panier.</p>
            <% end %>

            <% if current_user&.admin? %>
              <%= button_to "Supprimer", dish, method: :delete, data: { turbo_confirm: "Supprimer ce plat ?" }, class: "mt-2 w-full px-4 py-2 bg-red-600 hover:bg-red-500 text-white rounded-md font-medium" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center my-10 text-gray-600 text-lg">Aucun plat disponible pour le moment.</p>
  <% end %>
</div>
