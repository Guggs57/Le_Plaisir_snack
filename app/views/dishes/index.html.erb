<h1 class="menu-title">Notre Menu</h1>

<% if @dishes.any? %>
  <div class="dish-list">
    <% @dishes.each do |dish| %>
      <div class="dish-card">
        <% if dish.image.present? %>
          <%= image_tag(dish.image, alt: dish.title, class: "dish-image") %>
        <% else %>
          <div class="dish-no-image">
            Pas d'image
          </div>
        <% end %>

        <h2 class="dish-title"><%= dish.title %></h2>
        <p class="dish-description"><%= truncate(dish.description, length: 80) %></p>
        <p class="dish-price"><%= number_to_currency(dish.price, unit: "€") %></p>

        <%= link_to "Voir le détail", dish_path(dish), class: "btn-primary" %>
      </div>
    <% end %>
  </div>
<% else %>
  <p>Aucun plat disponible pour le moment.</p>
<% end %>
