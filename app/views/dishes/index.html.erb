<% content_for :title, "Dishes" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Dishes</h1>
    <%= link_to "New dish", new_dish_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="dishes" class="dishes-container">
    <% if @dishes.any? %>
      <% @dishes.each do |dish| %>
        <div class="dish-card">
          <%= render dish %>
          <div class="actions">
            <%= link_to "Show", dish, class: "btn show-btn" %>
            <%= link_to "Edit", edit_dish_path(dish), class: "btn edit-btn" %>
            <%= button_to "Destroy", dish, method: :delete, class: "btn destroy-btn", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No dishes found.</p>
    <% end %>
  </div>
</div>
