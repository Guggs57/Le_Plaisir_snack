<div id="<%= dom_id dish %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= dish.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= dish.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Price:</strong>
    <%= dish.price %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Image url:</strong>
    <%= dish.image_url %>
  </div>
</div>
