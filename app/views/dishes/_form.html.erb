<%= form_with(model: dish, local: true, html: { multipart: true }) do |form| %>
  <% if dish.errors.any? %>
    <div class="bg-red-100 text-red-700 p-4 mb-4 rounded">
      <h2 class="font-semibold">Erreur(s) :</h2>
      <ul class="list-disc pl-5">
        <% dish.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :title %>
    <%= form.text_field :title, class: "border rounded w-full py-2 px-3" %>
  </div>

  <div class="mb-4">
    <%= form.label :description %>
    <%= form.text_area :description, class: "border rounded w-full py-2 px-3" %>
  </div>

  <div class="mb-4">
    <%= form.label :price %>
    <%= form.number_field :price, step: 0.01, class: "border rounded w-full py-2 px-3" %>
  </div>

  <div class="mb-4">
    <%= form.label :image, "Image du plat" %>
    <%= form.file_field :image, class: "mt-1" %>
  </div>

  <div class="flex justify-end">
    <%= form.submit class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-500" %>
  </div>
<% end %>
