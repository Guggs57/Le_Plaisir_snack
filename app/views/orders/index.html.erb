<% content_for :title, "Orders" %>

<div class="orders-wrapper">
  <% if notice.present? %>
    <p id="notice"><%= notice %></p>
  <% end %>

  <div class="orders-header">
    <h1>Orders</h1>
    <%= link_to "New order", new_order_path, class: "new-order-button" %>
  </div>

  <div id="orders">
    <% if @orders.any? %>
      <% @orders.each do |order| %>
        <div class="order-entry">
          <%= render order %>
          <div class="order-actions">
            <%= link_to "Show", order, class: "order-btn show" %>
            <%= link_to "Edit", edit_order_path(order), class: "order-btn edit" %>
            <%= button_to "Destroy", order, method: :delete, class: "order-btn destroy", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="no-orders">No orders found.</p>
    <% end %>
  </div>
</div>
