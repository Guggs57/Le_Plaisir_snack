<h2>Commande n°<%= @order.id %></h2>

<ul>
  <% @order.order_dishes.each do |od| %>
    <li>
      <%= od.quantity %> x <%= od.dish.title %> - <%= number_to_currency(od.dish.price * od.quantity) %>
    </li>
  <% end %>
</ul>

<p><strong>Total :</strong> <%= number_to_currency(@order.total_price) %></p>
