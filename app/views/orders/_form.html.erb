<%= form_with(model: order, class: "order-form") do |form| %>
  <% if order.errors.any? %>
    <div id="error_explanation" class="form-errors">
      <h2><%= pluralize(order.errors.count, "erreur") %> ont empêché la commande d’être enregistrée :</h2>
      <ul>
        <% order.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group <%= "has-error" if order.errors[:user_id].any? %>">
    <%= form.label :user_id, "ID utilisateur" %>
    <%= form.text_field :user_id, class: "form-input" %>
  </div>

  <div class="form-group <%= "has-error" if order.errors[:total_price].any? %>">
    <%= form.label :total_price, "Prix total" %>
    <%= form.text_field :total_price, class: "form-input" %>
  </div>

  <div class="form-group <%= "has-error" if order.errors[:status].any? %>">
    <%= form.label :status, "Statut" %>
    <%= form.text_field :status, class: "form-input" %>
  </div>

  <div class="form-submit">
    <%= form.submit "Enregistrer", class: "btn btn-primary" %>
  </div>
<% end %>
